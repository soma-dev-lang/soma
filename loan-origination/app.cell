// ═══════════════════════════════════════════════════════════════════
// Loan Origination — Verified Consumer Lending Pipeline
//
// A real consumer lending workflow: applicant submits → KYC →
// underwriting → offer → accept/fund. The state machine PROVES
// every application terminates in `closed` (no zombie applications).
//
// 4 cells:
//   KycVerifier    — reads applicant data, verdict + reasoning
//   Underwriter    — reads applicant + KYC + bureau, risk + decision
//   OfferGenerator — drafts a personalized offer letter
//   OriginationDesk — orchestrator + state machine + HTTP API
//
// soma serve loan-origination/app.cell -p 8080
// ═══════════════════════════════════════════════════════════════════

// ── KycVerifier Agent ──────────────────────────────────────────

cell agent KycVerifier [model: smart] {
    on verify_kyc(applicant: Map) {
        let name = applicant.name ?? "unknown"
        let dob = applicant.dob ?? "unknown"
        let id_type = applicant.id_type ?? "none"
        let id_num = applicant.id_number ?? "none"
        let address = applicant.address ?? "unknown"
        let country = applicant.country ?? "unknown"

        let prompt = "You are a KYC analyst. Decide if this applicant passes basic identity verification. Watch for: missing fields, sanctioned countries, mismatched address, suspicious ID format.\n\nName: {name}\nDOB: {dob}\nID type: {id_type}\nID number: {id_num}\nAddress: {address}\nCountry: {country}\n\nReturn three lines exactly:\nVERDICT: VERIFIED|NEEDS_REVIEW|REJECTED\nREASON: <one sentence>\nFLAGS: <comma-separated, or NONE>"
        let result = think(prompt)
        map("agent", "kyc", "applicant", name, "result", result)
    }
}

// ── Underwriter Agent ──────────────────────────────────────────

cell agent Underwriter [model: smart] {
    on assess(applicant: Map, kyc: String) {
        let name = applicant.name ?? "unknown"
        let income = applicant.annual_income ?? "0"
        let debt = applicant.monthly_debt ?? "0"
        let employed = applicant.employed ?? "unknown"
        let credit = applicant.credit_score ?? "unknown"
        let amount = applicant.requested_amount ?? "0"
        let purpose = applicant.purpose ?? "unspecified"

        let prompt = "You are a credit underwriter. Given the borrower profile and KYC notes, produce a risk assessment and a decision.\n\nName: {name}\nAnnual income: {income}\nMonthly debt: {debt}\nEmployed: {employed}\nCredit score: {credit}\nRequested amount: {amount}\nPurpose: {purpose}\n\nKYC notes:\n{kyc}\n\nReturn four lines exactly:\nDECISION: APPROVE|DECLINE|MORE_INFO\nRISK_SCORE: <integer 1-100, where 1 is best>\nRATE_BPS: <suggested APR in basis points, e.g. 1099 = 10.99%>\nREASON: <one sentence>"
        let result = think(prompt)
        map("agent", "underwriter", "applicant", name, "result", result)
    }
}

// ── OfferGenerator Agent ───────────────────────────────────────

cell agent OfferGenerator [model: smart] {
    on draft_offer(applicant: Map, decision: String, amount: String, rate_bps: String, term_months: String) {
        let name = applicant.name ?? "applicant"
        let prompt = "Write a 4-sentence offer letter (calm, plain English, no marketing) for {name}: principal {amount} USD, term {term_months} months, rate {rate_bps} basis points APR. End with one sentence on how to accept or decline."
        let result = think(prompt)
        map("agent", "offer", "result", result)
    }
}

// ── OriginationDesk — Orchestrator ─────────────────────────────

cell OriginationDesk {
    memory {
        applications: Map<String, String> [persistent, consistent]
        decisions:    Map<String, String> [persistent, consistent]
        offers:       Map<String, String> [persistent, consistent]
        policy:       Map<String, String> [persistent]
    }

    state application {
        initial: submitted
        submitted -> kyc_pending
        submitted -> withdrawn
        kyc_pending -> underwriting
        kyc_pending -> rejected
        kyc_pending -> withdrawn
        underwriting -> decision_pending
        underwriting -> rejected
        underwriting -> withdrawn
        decision_pending -> offered
        decision_pending -> rejected
        offered -> accepted
        offered -> declined
        offered -> withdrawn
        accepted -> funded
        accepted -> withdrawn
        funded -> closed
        rejected -> closed
        declined -> closed
        withdrawn -> closed
    }

    // ── Private helpers ────────────────────────────────────────

    on _load(id: String) {
        let raw = applications.get(id)
        if raw == () {
            return ()
        }
        from_json(raw)
    }

    on _save(id: String, app: Map) {
        applications.set(id, to_json(app))
    }

    on _record_decision(id: String, kind: String, body: String) {
        let entry = map(
            "application", id,
            "kind", kind,
            "body", body,
            "ts", to_string(now())
        )
        let key = id + "_" + kind + "_" + to_string(now())
        decisions.set(key, to_json(entry))
    }

    on _parse_kyc_verdict(text: String) {
        let v = "NEEDS_REVIEW"
        if contains(text, "VERIFIED") { v = "VERIFIED" }
        if contains(text, "REJECTED") { v = "REJECTED" }
        v
    }

    on _parse_uw_decision(text: String) {
        let d = "MORE_INFO"
        if contains(text, "APPROVE") { d = "APPROVE" }
        if contains(text, "DECLINE") { d = "DECLINE" }
        d
    }

    on _max_amount() {
        let raw = policy.get("max_amount")
        if raw == () { return "50000" }
        raw
    }

    on _term_months() {
        let raw = policy.get("term_months")
        if raw == () { return "36" }
        raw
    }

    // ── Public: submit ─────────────────────────────────────────
    //
    // Hot path: submit → kyc → underwrite → offer (or reject).

    on submit(payload: Map) {
        let id = "APP-" + to_string(next_id())
        let name = payload.name ?? "unknown"
        let amount = payload.requested_amount ?? "0"

        // Policy guard: hard-cap requested amount before LLM spend
        let cap = _max_amount()
        if to_int(amount) > to_int(cap) {
            let app_capped = map(
                "id", id,
                "name", name,
                "status", "rejected",
                "reason", "requested amount {amount} exceeds policy cap {cap}",
                "opened_at", to_string(now())
            )
            _save(id, app_capped)
            transition(id, "rejected")
            _record_decision(id, "policy_cap", "amount {amount} > cap {cap}")
            transition(id, "closed")
            let final_app = app_capped |> with("status", "closed") |> with("closed_at", to_string(now()))
            _save(id, final_app)
            return map("id", id, "status", "closed", "rejected", true, "reason", "policy_cap")
        }

        let app = map(
            "id", id,
            "name", name,
            "requested_amount", amount,
            "purpose", payload.purpose ?? "unspecified",
            "status", "submitted",
            "opened_at", to_string(now())
        )
        _save(id, app)

        // ── KYC ────────────────────────────────────────────────
        transition(id, "kyc_pending")
        let app1 = app |> with("status", "kyc_pending")
        _save(id, app1)

        let kyc = delegate("KycVerifier", "verify_kyc", payload)
        let kyc_text = kyc.result
        _record_decision(id, "kyc", kyc_text)
        let kyc_verdict = _parse_kyc_verdict(kyc_text)
        let app2 = app1 |> with("kyc", kyc_verdict) |> with("kyc_notes", kyc_text)
        _save(id, app2)

        if kyc_verdict == "REJECTED" {
            transition(id, "rejected")
            _record_decision(id, "kyc_rejected", kyc_text)
            transition(id, "closed")
            let final_app = app2 |> with("status", "closed") |> with("closed_at", to_string(now()))
            _save(id, final_app)
            return map("id", id, "status", "closed", "stage", "kyc", "verdict", "REJECTED")
        }

        // ── Underwriting ───────────────────────────────────────
        transition(id, "underwriting")
        let app3 = app2 |> with("status", "underwriting")
        _save(id, app3)

        let uw = delegate("Underwriter", "assess", payload, kyc_text)
        let uw_text = uw.result
        _record_decision(id, "underwriting", uw_text)
        let uw_decision = _parse_uw_decision(uw_text)
        let app4 = app3 |> with("uw_decision", uw_decision) |> with("uw_notes", uw_text)
        _save(id, app4)

        if uw_decision == "DECLINE" {
            transition(id, "rejected")
            _record_decision(id, "underwriting_declined", uw_text)
            transition(id, "closed")
            let final_app = app4 |> with("status", "closed") |> with("closed_at", to_string(now()))
            _save(id, final_app)
            return map("id", id, "status", "closed", "stage", "underwriting", "decision", "DECLINE")
        }

        // ── Decision pending → Offer ───────────────────────────
        transition(id, "decision_pending")
        let app5 = app4 |> with("status", "decision_pending")
        _save(id, app5)

        if uw_decision == "MORE_INFO" {
            // Underwriter wanted more info; we still offer at conservative terms
            // for the demo, but flag the application.
            let app_flag = app5 |> with("flag", "more_info_requested")
            _save(id, app_flag)
        }

        // Offer terms — extract a rate hint from the underwriter text if present.
        // Defaults: 36 months, 1599 bps APR.
        let rate_bps = "1599"
        if contains(uw_text, "RATE_BPS") {
            // best-effort: leave the LLM-suggested rate as opaque text in the audit
        }
        let term = _term_months()

        let offer = delegate("OfferGenerator", "draft_offer", payload, uw_text, amount, rate_bps, term)
        let offer_text = offer.result
        let offer_record = map(
            "application", id,
            "principal", amount,
            "term_months", term,
            "rate_bps", rate_bps,
            "letter", offer_text,
            "drafted_at", to_string(now())
        )
        offers.set(id, to_json(offer_record))

        transition(id, "offered")
        let app6 = app5
            |> with("status", "offered")
            |> with("offer_principal", amount)
            |> with("offer_rate_bps", rate_bps)
            |> with("offer_term_months", term)
        _save(id, app6)
        _record_decision(id, "offered", offer_text)

        map("id", id, "status", "offered", "principal", amount, "rate_bps", rate_bps, "term_months", term, "letter", offer_text)
    }

    // ── Borrower actions on the offer ──────────────────────────

    on accept(id: String) {
        let app = _load(id)
        if app == () { return map("error", "not found") }
        if app.status != "offered" {
            return map("error", "application not in 'offered' state", "status", app.status)
        }
        transition(id, "accepted")
        let updated = app |> with("status", "accepted") |> with("accepted_at", to_string(now()))
        _save(id, updated)
        _record_decision(id, "accepted", "borrower accepted offer")
        map("id", id, "status", "accepted")
    }

    on decline(id: String, reason: String) {
        let app = _load(id)
        if app == () { return map("error", "not found") }
        transition(id, "declined")
        let updated = app
            |> with("status", "declined")
            |> with("decline_reason", reason)
        _save(id, updated)
        _record_decision(id, "declined", reason)
        transition(id, "closed")
        let final_app = updated |> with("status", "closed") |> with("closed_at", to_string(now()))
        _save(id, final_app)
        map("id", id, "status", "closed", "declined", true)
    }

    on withdraw(id: String, reason: String) {
        let app = _load(id)
        if app == () { return map("error", "not found") }
        transition(id, "withdrawn")
        let updated = app
            |> with("status", "withdrawn")
            |> with("withdraw_reason", reason)
        _save(id, updated)
        _record_decision(id, "withdrawn", reason)
        transition(id, "closed")
        let final_app = updated |> with("status", "closed") |> with("closed_at", to_string(now()))
        _save(id, final_app)
        map("id", id, "status", "closed", "withdrawn", true)
    }

    on fund(id: String) {
        let app = _load(id)
        if app == () { return map("error", "not found") }
        if app.status != "accepted" {
            return map("error", "application not in 'accepted' state", "status", app.status)
        }
        transition(id, "funded")
        let updated = app |> with("status", "funded") |> with("funded_at", to_string(now()))
        _save(id, updated)
        _record_decision(id, "funded", "wire transfer initiated")
        transition(id, "closed")
        let final_app = updated |> with("status", "closed") |> with("closed_at", to_string(now()))
        _save(id, final_app)
        map("id", id, "status", "closed", "funded", true)
    }

    // ── Policy admin ───────────────────────────────────────────

    on set_policy(key: String, value: String) {
        policy.set(key, value)
        map("key", key, "value", value)
    }

    on get_policy() {
        let out = list()
        for k in policy.keys() {
            let entry = map("key", k, "value", policy.get(k))
            out = push(out, entry)
        }
        out
    }

    // ── Read API ───────────────────────────────────────────────

    on get_application(id: String) {
        let app = _load(id)
        if app == () { return map("error", "not found") }
        app
    }

    on list_applications() {
        let out = list()
        for k in applications.keys() {
            let app = from_json(applications.get(k))
            out = push(out, app)
        }
        out
    }

    on get_offer(id: String) {
        let raw = offers.get(id)
        if raw == () { return map("error", "no offer") }
        from_json(raw)
    }

    on get_decisions(id: String) {
        let out = list()
        for k in decisions.keys() {
            if starts_with(k, id + "_") {
                let raw = decisions.get(k)
                out = push(out, from_json(raw))
            }
        }
        out
    }

    // ── HTTP routing ───────────────────────────────────────────

    on request(method: String, path: String, body: String) {
        let req = map("method", method, "path", path)
        match req {
            {method: "GET", path: "/"} -> map(
                "name", "Soma Loan Origination",
                "applications", applications.len(),
                "endpoints", list(
                    "POST /applications      body: {name, dob, id_type, id_number, address, country, annual_income, monthly_debt, employed, credit_score, requested_amount, purpose}",
                    "POST /accept            body: {id}",
                    "POST /decline           body: {id, reason}",
                    "POST /withdraw          body: {id, reason}",
                    "POST /fund              body: {id}",
                    "POST /policy            body: {key, value}",
                    "GET  /applications",
                    "GET  /application/{id}",
                    "GET  /offer/{id}",
                    "GET  /decisions/{id}",
                    "GET  /policy"
                )
            )
            {method: "POST", path: "/applications"} -> submit(from_json(body))
            {method: "POST", path: "/accept"} -> {
                let d = from_json(body)
                accept(d.id ?? "")
            }
            {method: "POST", path: "/decline"} -> {
                let d = from_json(body)
                decline(d.id ?? "", d.reason ?? "")
            }
            {method: "POST", path: "/withdraw"} -> {
                let d = from_json(body)
                withdraw(d.id ?? "", d.reason ?? "")
            }
            {method: "POST", path: "/fund"} -> {
                let d = from_json(body)
                fund(d.id ?? "")
            }
            {method: "POST", path: "/policy"} -> {
                let d = from_json(body)
                set_policy(d.key ?? "", d.value ?? "")
            }
            {method: "GET", path: "/applications"} -> list_applications()
            {method: "GET", path: "/policy"} -> get_policy()
            {method: "GET", path: "/application/" + id} -> get_application(id)
            {method: "GET", path: "/offer/" + id} -> get_offer(id)
            {method: "GET", path: "/decisions/" + id} -> get_decisions(id)
            _ -> response(404, map("error", "not found"))
        }
    }
}
