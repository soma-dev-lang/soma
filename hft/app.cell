// ═══════════════════════════════════════════════════════════════════
// HFT Engine — Verified High-Frequency Trading Automaton
//
// A complete trading system where every safety property is proven
// at compile time:
//
//   soma verify hft/app.cell
//   ✓ think-isolated (pure math, no LLM in the hot path)
//   ✓ termination: all handlers structurally terminate
//   ✓ eventually(settled): every order reaches a terminal state
//   ✓ no deadlocks in the order lifecycle
//   ✓ budget proven for SignalEngine: peak ≤ declared
//
// Architecture:
//   prices (tick) → SignalEngine (pure) → target weights
//   target weights + current positions → ExecutionEngine → orders
//   every order → RiskManager (pre-trade check) → fill or reject
//   fills → RiskManager (drawdown tracking) → halt if breached
//
// The LLM is NOWHERE in this pipeline. Every handler is pure
// deterministic math. `soma verify` proves think-isolated because
// there are zero think() calls — the strongest possible isolation.
//
//   soma serve hft/app.cell -p 8080
// ═══════════════════════════════════════════════════════════════════

use lib::signals
use lib::risk
use lib::execution

cell HFTEngine {
    memory {
        prices:        Map<String, String> [ephemeral, capacity(100), max_value_bytes(128)]
        price_history: Map<String, String> [persistent, capacity(100), max_value_bytes(8192)]
        config:        Map<String, String> [ephemeral, capacity(20), max_value_bytes(256)]
        tick_log:      Map<String, String> [persistent, capacity(100000), max_key_bytes(32), max_value_bytes(512)]
    }

    // ── Configuration ──────────────────────────────────────────

    on setup(payload: Map) {
        // Universe of symbols to trade.
        let symbols = payload.symbols ?? list("AAPL", "MSFT", "GOOG")
        config.set("symbols", to_json(symbols))
        config.set("threshold", payload.threshold ?? "0.5")
        config.set("allow_short", payload.allow_short ?? "false")
        config.set("nav", payload.nav ?? "1000000")

        // Initialize risk limits.
        delegate("RiskManager", "set_limits", map(
            "max_position", payload.max_position ?? "10000",
            "max_drawdown", payload.max_drawdown ?? "0.05",
            "max_notional", payload.max_notional ?? "500000"
        ))
        delegate("RiskManager", "init_equity", payload.nav ?? "1000000")

        map("status", "configured")
    }

    // ── Price feed ─────────────────────────────────────────────
    //
    // In a real system this would be a WebSocket or FIX feed.
    // Here it's a POST endpoint that the market data adapter calls.

    on tick(payload: Map) {
        // payload: { prices: { "AAPL": "175.50", "MSFT": "420.30", ... } }
        let tick_prices = payload.prices ?? map()
        let tick_id = to_string(next_id())

        // Update current prices.
        for [loop_bound(100)] sym in tick_prices.keys() {
            let p = tick_prices.get(sym)
            prices.set(sym, p)

            // Append to history (load, push, save).
            let hist_raw = price_history.get(sym)
            let hist = list()
            if hist_raw != () {
                hist = from_json(hist_raw)
            }
            hist = push(hist, p)
            // Keep last 200 ticks.
            if len(hist) > 200 {
                hist = hist |> filter(x => true) |> top(200)
            }
            price_history.set(sym, to_json(hist))
        }

        // Compute signals for each symbol.
        let symbols_raw = config.get("symbols")
        let symbols = list("AAPL", "MSFT", "GOOG")
        if symbols_raw != () {
            symbols = from_json(symbols_raw)
        }
        let threshold = to_float(config.get("threshold") ?? "0.5")

        let all_signals = list()
        for [loop_bound(100)] sym in symbols {
            let hist_raw = price_history.get(sym)
            if hist_raw != () {
                let hist = from_json(hist_raw)
                let sig = delegate("SignalEngine", "compute_signal", hist, threshold)
                all_signals = push(all_signals, map(
                    "symbol", sym,
                    "signal", sig.signal ?? "0",
                    "reason", sig.reason ?? "unknown"
                ))
            }
        }

        // Compute target weights.
        let allow_short = config.get("allow_short") ?? "false"
        let targets = delegate("SignalEngine", "compute_targets", all_signals, allow_short)

        // Compute trades: compare current positions (from risk manager)
        // against target weights.
        let nav = to_float(config.get("nav") ?? "1000000")
        let current_positions = map()
        for [loop_bound(100)] sym in symbols {
            let pos = delegate("RiskManager", "get_position", sym)
            current_positions = current_positions |> with(sym, to_string(pos))
        }

        let trades = delegate("ExecutionEngine", "compute_trades",
            current_positions, targets, tick_prices, nav)

        // Execute trades (each goes through risk check → order lifecycle → fill).
        let exec_result = map("n_sent", 0, "n_rejected", 0)
        if len(trades) > 0 {
            exec_result = delegate("ExecutionEngine", "execute_rebalance", trades)
        }

        // Log the tick.
        let risk = delegate("RiskManager", "get_risk_state")
        tick_log.set(tick_id, to_json(map(
            "tick", tick_id,
            "n_signals", len(all_signals),
            "n_targets", len(targets.keys()),
            "n_trades", len(trades),
            "n_sent", exec_result.n_sent,
            "n_rejected", exec_result.n_rejected,
            "risk_status", risk.status,
            "drawdown", risk.drawdown,
            "ts", to_string(now())
        )))

        map(
            "tick", tick_id,
            "signals", all_signals,
            "targets", targets,
            "trades_computed", len(trades),
            "sent", exec_result.n_sent,
            "rejected", exec_result.n_rejected,
            "risk", risk
        )
    }

    // ── Operator controls ──────────────────────────────────────

    on halt() {
        delegate("RiskManager", "halt")
    }

    on resume() {
        delegate("RiskManager", "resume")
    }

    // ── Read API ───────────────────────────────────────────────

    on status() {
        let risk = delegate("RiskManager", "get_risk_state")
        map(
            "risk", risk,
            "nav", config.get("nav") ?? "0",
            "tick_count", tick_log.len()
        )
    }

    on get_fills(n: Int) {
        delegate("ExecutionEngine", "recent_fills", n)
    }

    // ── HTTP routing ───────────────────────────────────────────

    on request(method: String, path: String, body: String) {
        let req = map("method", method, "path", path)
        match req {
            {method: "GET", path: "/"} -> map(
                "name", "Soma HFT Engine",
                "endpoints", list(
                    "POST /setup       body: {symbols, threshold, nav, max_position, max_drawdown, allow_short}",
                    "POST /tick        body: {prices: {sym: price, ...}}",
                    "POST /halt",
                    "POST /resume",
                    "GET  /status",
                    "GET  /fills/{n}",
                    "GET  /order/{id}"
                )
            )
            {method: "POST", path: "/setup"} -> setup(from_json(body))
            {method: "POST", path: "/tick"} -> tick(from_json(body))
            {method: "POST", path: "/halt"} -> halt()
            {method: "POST", path: "/resume"} -> resume()
            {method: "GET", path: "/status"} -> status()
            {method: "GET", path: "/fills/" + n} -> get_fills(to_int(n))
            {method: "GET", path: "/order/" + id} -> delegate("ExecutionEngine", "get_order", id)
            _ -> response(404, map("error", "not found"))
        }
    }
}
