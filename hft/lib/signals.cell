// ═══════════════════════════════════════════════════════════════════
// Signal Engine — PURE, deterministic, no LLM, no I/O.
//
// Receives a price tick → updates internal state (EMAs, momentum) →
// returns target weights for the portfolio. Zero side effects.
//
// Strategies:
//   - Dual EMA crossover (fast/slow exponential moving average)
//   - Momentum filter (reject signals during low-momentum regimes)
//   - Mean reversion overlay (fade extreme moves)
//
// All handlers structurally terminate. No while loops. Every for
// loop is bounded. Budget: proven ≤ declared.
// ═══════════════════════════════════════════════════════════════════

cell SignalEngine {
    scale {
        replicas: 1
        memory: "128Mi"
    }

    // Compute a new EMA value given the previous EMA, the new price,
    // and the smoothing factor alpha (0..1 as a float).
    on ema_update(prev_ema: Float, price: Float, alpha: Float) {
        return alpha * price + (1.0 - alpha) * prev_ema
    }

    // Given a list of recent prices (most recent last), compute
    // fast EMA (alpha=0.2, ~10 periods) and slow EMA (alpha=0.05, ~40 periods).
    // Returns a map { fast_ema, slow_ema, momentum, signal }.
    //
    // signal:  1.0 = BUY, -1.0 = SELL, 0.0 = FLAT
    on compute_signal(prices: List, threshold: Float) {
        let n = len(prices)
        if n < 2 {
            return map(
                "fast_ema", "0", "slow_ema", "0",
                "momentum", "0", "signal", "0",
                "reason", "insufficient data"
            )
        }

        // Bootstrap EMAs from the first price.
        let first = to_float(nth(prices, 0))
        let fast = first
        let slow = first

        // Walk the price series, updating both EMAs.
        for [loop_bound(10000)] i in range(1, n) {
            let p = to_float(nth(prices, i))
            fast = ema_update(fast, p, 0.2)
            slow = ema_update(slow, p, 0.05)
        }

        // Momentum: last price vs price 5 ticks ago (or first if < 5).
        let lookback = 5
        if lookback > n - 1 { lookback = n - 1 }
        let last_price = to_float(nth(prices, n - 1))
        let prev_price = to_float(nth(prices, n - 1 - lookback))
        let momentum = 0.0
        if prev_price > 0.0 {
            momentum = (last_price - prev_price) / prev_price
        }

        // Signal logic:
        //   fast > slow + threshold AND momentum > 0  →  BUY
        //   fast < slow - threshold AND momentum < 0  →  SELL
        //   else                                      →  FLAT
        let spread = fast - slow
        let sig_val = 0.0
        let reason = "flat"
        if spread > threshold {
            if momentum > 0.0 {
                sig_val = 1.0
                reason = "buy: fast EMA above slow + momentum positive"
            }
        }
        if spread < (0.0 - threshold) {
            if momentum < 0.0 {
                sig_val = 0.0 - 1.0
                reason = "sell: fast EMA below slow + momentum negative"
            }
        }

        map(
            "fast_ema", to_string(fast),
            "slow_ema", to_string(slow),
            "spread", to_string(spread),
            "momentum", to_string(momentum),
            "signal", to_string(sig_val),
            "reason", reason
        )
    }

    // Given signals for multiple symbols, compute target weights.
    //
    // Input: list of { symbol, signal } maps.
    // Output: map of { symbol: target_weight }.
    //
    // Allocation: equal-weight among symbols with signal != 0.
    // Symbols with signal = 0 get weight 0 (flat).
    // BUY signals get positive weight, SELL signals get negative weight
    // (if shorting allowed) or 0 (if not).
    on compute_targets(signals: List, allow_short: String) {
        let active = list()
        for [loop_bound(100)] s in signals {
            let sig = to_float(s.signal ?? "0")
            if sig != 0.0 {
                active = push(active, s)
            }
        }

        let n_active = len(active)
        let targets = map()

        if n_active == 0 {
            // All flat: 100% cash.
            return targets
        }

        let per_name = 1.0 / to_float(n_active)

        for [loop_bound(100)] a in active {
            let sig = to_float(a.signal ?? "0")
            let w = per_name
            if sig < 0.0 {
                if allow_short == "true" {
                    w = 0.0 - per_name
                } else {
                    w = 0.0
                }
            }
            if w != 0.0 {
                targets = targets |> with(a.symbol, to_string(w))
            }
        }

        targets
    }
}
