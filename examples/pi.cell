// Compute 100,000 digits of PI — single [native] handler
//
// Gibbons streaming spigot compiled to Rust/GMP via [native].
// The entire computation runs in native code — no interpreter dispatch.
//
// Run: soma run pi.cell

cell Pi {

    on compute(target: Int) [native] {
        let q = 1
        let r = 0
        let s = 0
        let t = 1
        let k = 1
        let digits = 0
        let result = ""

        while digits <= target {
            // extract: floor((q*3 + r) / (s*3 + t))
            let num = q * 3
            num = num + r
            let den = s * 3
            den = den + t
            let d = num / den

            // safe check: floor((q*4 + r) / (s*4 + t))
            let num4 = q * 4
            num4 = num4 + r
            let den4 = s * 4
            den4 = den4 + t
            let d4 = num4 / den4

            if d == d4 {
                if digits == 0 {
                    digits = 1
                } else {
                    result = result + to_string(d)
                    digits = digits + 1
                }
                // consume: q = 10*(q - d*s), r = 10*(r - d*t)
                let ds = d * s
                let nq = q - ds
                nq = nq * 10
                let dt = d * t
                let nr = r - dt
                nr = nr * 10
                q = nq
                r = nr
            } else {
                // absorb: compose with (k, 4k+2, 0, 2k+1)
                let u = 4 * k
                u = u + 2
                let v = 2 * k
                v = v + 1
                let nq = q * k
                let qu = q * u
                let rv = r * v
                let nr = qu + rv
                let ns = s * k
                let su = s * u
                let tv = t * v
                let nt = su + tv
                q = nq
                r = nr
                s = ns
                t = nt
                k = k + 1
            }
        }

        return result
    }

    on check_ref(buf: String, ref_digits: String) {
        let mismatches = 0
        let i = 0
        while i < len(buf) {
            if i < len(ref_digits) {
                let got = substring(buf, i, i + 1)
                let exp = substring(ref_digits, i, i + 1)
                if got != exp {
                    mismatches = mismatches + 1
                    if mismatches <= 10 {
                        print("    MISMATCH at digit {i + 1}: got {got}, expected {exp}")
                    }
                }
            }
            i = i + 1
        }
        return mismatches
    }

    on run() {
        let ref_1k = ""
        let ref_50k = "06526234053394391421112718106910522900246574236041"
        let ref_100k = "70150789337728658035712790913767420805655493624646"

        let target = 100000

        print("PI spigot [native] — computing {target} digits")
        print("===============================================")
        print("")

        let start = now_ms()
        let pi_digits = compute(target)
        let elapsed = now_ms() - start

        print("Computed {len(pi_digits)} digits in {elapsed}ms")
        print("")

        // Verify first 1000
        let first_1k = substring(pi_digits, 0, 1000)
        let errors = check_ref(first_1k, ref_1k)
        if errors == 0 {
            print("  [1,000] ALL 1000 digits match reference")
        } else {
            print("  [1,000] {errors} mismatches!")
        }

        // Verify at 50K
        if len(pi_digits) >= 50000 {
            let last50 = substring(pi_digits, 49950, 50000)
            if last50 == ref_50k {
                print("  [50,000] last 50 digits match reference")
            } else {
                print("  [50,000] MISMATCH!")
                print("    got: {last50}")
                print("    exp: {ref_50k}")
            }
        }

        // Verify at 100K
        if len(pi_digits) >= 100000 {
            let last50 = substring(pi_digits, 99950, 100000)
            if last50 == ref_100k {
                print("  [100,000] last 50 digits match reference")
            } else {
                print("  [100,000] MISMATCH!")
                print("    got: {last50}")
                print("    exp: {ref_100k}")
            }
        }

        print("")
        print("Done: {len(pi_digits)} digits of PI in {elapsed}ms")
        if errors == 0 {
            print("ALL checkpoints PASSED")
        }
    }
}
