// Unbounded PI spigot — streams digits and verifies against known decimals
//
// Uses the Gibbons streaming algorithm with linear fractional transformations.
// BigInt auto-promotion handles arbitrary precision transparently.
// Verified at checkpoints: 1K (full), 50K and 100K (50-digit snapshots).
//
// Run: soma run pi.cell

cell Pi {

    // Extract digit: floor((q*3+r)/(s*3+t))
    on extract(q: Int, r: Int, s: Int, t: Int) {
        return (q * 3 + r) / (s * 3 + t)
    }

    on extract4(q: Int, r: Int, s: Int, t: Int) {
        return (q * 4 + r) / (s * 4 + t)
    }

    // Absorb term k into LFT (q,r,s,t)
    on absorb(q: Int, r: Int, s: Int, t: Int, k: Int) {
        let u = 4 * k + 2
        let v = 2 * k + 1
        return list(q * k, q * u + r * v, s * k, s * u + t * v)
    }

    // Consume digit d
    on consume(q: Int, r: Int, s: Int, t: Int, d: Int) {
        return list(10 * (q - d * s), 10 * (r - d * t), s, t)
    }

    on check_ref(buf: String, ref_digits: String, pos: Int) {
        let mismatches = 0
        let i = 0
        while i < len(buf) {
            let got = substring(buf, i, i + 1)
            let exp = substring(ref_digits, i, i + 1)
            if got != exp {
                mismatches = mismatches + 1
                print("    MISMATCH at digit {pos - 49 + i}: got {got}, expected {exp}")
            }
            i = i + 1
        }
        return mismatches
    }

    on run() {
        let ref_1k = ""
        let ref_50k = "06526234053394391421112718106910522900246574236041"
        let ref_100k = "70150789337728658035712790913767420805655493624646"

        let target = 100000
        let q = 1
        let r = 0
        let s = 0
        let t = 1
        let k = 1
        let digits = 0
        let errors = 0
        let start = now_ms()
        let buf = ""

        print("PI spigot — computing {target} digits")
        print("======================================")
        print("")

        while digits <= target {
            let d = extract(q, r, s, t)
            if d == extract4(q, r, s, t) {
                if digits == 0 {
                    digits = 1
                    let st = consume(q, r, s, t, d)
                    q = st.get(0)
                    r = st.get(1)
                    s = st.get(2)
                    t = st.get(3)
                } else {
                    let pos = digits - 1
                    if pos < len(ref_1k) {
                        let expected = substring(ref_1k, pos, pos + 1)
                        if to_string(d) != expected {
                            errors = errors + 1
                            print("  MISMATCH at digit {digits}: got {d}, expected {expected}")
                        }
                    }

                    buf = buf + to_string(d)
                    if len(buf) > 50 {
                        buf = substring(buf, len(buf) - 50, len(buf))
                    }

                    digits = digits + 1
                    let st = consume(q, r, s, t, d)
                    q = st.get(0)
                    r = st.get(1)
                    s = st.get(2)
                    t = st.get(3)

                    let count = digits - 1
                    let elapsed = now_ms() - start
                    let rate = 0
                    if elapsed > 0 { rate = count * 1000 / elapsed }

                    if count == 1000 {
                        if errors == 0 {
                            print("  [1,000] ALL 1000 digits match reference  ({elapsed}ms)")
                        } else {
                            print("  [1,000] {errors} mismatches!  ({elapsed}ms)")
                        }
                    }

                    if count == 50000 {
                        let m = check_ref(buf, ref_50k, 50000)
                        errors = errors + m
                        if m == 0 {
                            print("  [50,000] last 50 digits match reference  ({elapsed}ms, ~{rate} d/s)")
                        } else {
                            print("  [50,000] {m} mismatches in checkpoint!  ({elapsed}ms)")
                        }
                        print("    ...{buf}")
                    }

                    if count == 100000 {
                        let m = check_ref(buf, ref_100k, 100000)
                        errors = errors + m
                        if m == 0 {
                            print("  [100,000] last 50 digits match reference  ({elapsed}ms, ~{rate} d/s)")
                        } else {
                            print("  [100,000] {m} mismatches in checkpoint!  ({elapsed}ms)")
                        }
                        print("    ...{buf}")
                    }

                    if count % 10000 == 0 {
                        if count != 50000 {
                            if count != 100000 {
                                print("  [{count}] ({elapsed}ms, ~{rate} d/s)")
                            }
                        }
                    }
                }
            } else {
                let st = absorb(q, r, s, t, k)
                q = st.get(0)
                r = st.get(1)
                s = st.get(2)
                t = st.get(3)
                k = k + 1
            }
        }

        let total_ms = now_ms() - start
        print("")
        print("Done: {digits - 1} digits of PI in {total_ms}ms")
        if errors == 0 {
            print("ALL checkpoints PASSED (1K full + 50K + 100K)")
        } else {
            print("TOTAL MISMATCHES: {errors}")
        }
    }
}
