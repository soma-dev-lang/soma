// ============================================================================
// V1 feature #4: Declarative adversaries — every guarantee names its threat
// ============================================================================
//
//   $ soma verify examples/v1/04_adversary_quorum.cell
//
// produces (excerpt):
//
//   ✓ no deadlocks (under network ∧ llm)
//   ✓ liveness: every state can eventually reach a terminal state (under network ∧ llm)
//   ✓ adversary 'network' [drop: up to 30% of messages; reorder: arbitrary; ...]
//   ✓ adversary 'llm' [output: arbitrary string; rate: bounded ( set_budget )]
//
// Every PASS message is now stamped with the adversary clause it was
// proven *under*. The LLM adversary is the honest answer to "what if the
// agent hallucinates" — currently nobody else has one.

adversary network {
    drop:      up to 30% of messages
    reorder:   arbitrary
    delay:     bounded(5s)
    partition: any minority subset
}

adversary llm {
    output: arbitrary string
    rate:   bounded(set_budget)
}

cell quorum_replicator {
    state replication {
        initial: leader
        leader -> committing
        committing -> committed
        committing -> aborted
        committed -> done
        aborted -> done
    }

    scale {
        replicas: 5
        consistency: strong
        tolerance: 2
        survives: network && llm
    }

    on run() {
        print("quorum_replicator: 5 replicas, strong consistency, survives network ∧ llm")
    }
}
