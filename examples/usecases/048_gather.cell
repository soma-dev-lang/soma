// 048: Gather — fan-out pattern with delegate
// Run: SOMA_LLM_MOCK=echo soma run examples/usecases/048_gather.cell
cell agent Researcher {
    face { signal research(topic: String) -> Map }
    state work { initial: idle  idle -> active  active -> done  * -> failed }
    on research(topic: String) {
        transition(topic, "active")
        let r = try { think("Research: {topic}") }
        if r.error != () {
            transition(topic, "failed")
            return map("status", "failed")
        }
        transition(topic, "done")
        map("status", "done", "findings", r.value)
    }
}
cell agent Gatherer {
    face { signal gather_all() -> Map }
    state work { initial: idle  idle -> gathering  gathering -> done  * -> failed }
    on gather_all() {
        transition("t", "gathering")
        let topics = list("AI", "quantum", "biotech")
        let results = list()
        for topic in topics {
            let r = delegate("Researcher", "research", topic)
            results = push(results, map("topic", topic, "result", r.findings))
        }
        transition("t", "done")
        print("gathered {len(results)} results")
        map("status", "done", "count", len(results))
    }
    on run() {
        let r = gather_all()
        print("status: {r.status}")
        return "done"
    }
}
