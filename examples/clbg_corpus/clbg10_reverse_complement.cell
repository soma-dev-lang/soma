// ============================================================================
// Computer Language Benchmarks Game — reverse-complement
// ============================================================================
//
// Read FASTA input, for each sequence reverse it and complement each
// nucleotide (A↔T, C↔G), output to stdout.
//
// CLBG full workload: ~250MB FASTA input.
// Reference (CLBG): Rust ~0.4s sequential.
//
// Uses Soma primitives:
//   - read_file(path)  — read FASTA input
//   - regex_replace    — strip headers / build complement
//   - strbuf + sb_push — build output
//   - write_str        — emit output

cell ClbgReverseComplement {

    // Generate a synthetic 1MB DNA + reverse-complement it.
    // Returns the length of the result.
    on bench_1mb() [native] {
        // Build 1MB of synthetic DNA into a strbuf
        let buf = strbuf(1100000)
        let i = 0
        while i < 16000 {
            sb_push(buf, "ACGTACGTACGTACGTACGTACGTACGTACGTACGTACGTACGTACGTACGTACGTACGTACGT")
            i = i + 1
        }
        let dna = sb_finish(buf)
        // Reverse-complement via regex_replace then a manual loop.
        // Soma's [native] doesn't yet have a fast string-reverse, so we
        // build the output via a Buf<Int> of complement bytes.
        let n = str_len(dna)
        let out = buffer(n)
        i = 0
        while i < n {
            let c = str_at(dna, n - 1 - i)
            // Complement: A(65)↔T(84), C(67)↔G(71)
            let comp = c
            if c == 65 { comp = 84 }
            if c == 84 { comp = 65 }
            if c == 67 { comp = 71 }
            if c == 71 { comp = 67 }
            buf_set(out, i, comp)
            i = i + 1
        }
        // Write the result via a strbuf
        let result = strbuf(n)
        i = 0
        while i < n {
            sb_push_char(result, buf_get(out, i))
            i = i + 1
        }
        let s = sb_finish(result)
        return str_len(s)
    }

    on run() {
        print("CLBG reverse-complement")
        print("=======================")
        print("")
        let start = now_ms()
        let n = bench_1mb()
        let elapsed = now_ms() - start
        print("  reverse-complement of 1MB DNA: {n} bytes  ({elapsed}ms)")
    }
}
