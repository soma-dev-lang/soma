// Factorial — uses Int (fast, 64-bit, overflows are errors)

cell Fact {
    face {
        signal compute(n: Int) -> Int
        promise "returns n factorial"
    }

    on compute(n: Int) {
        if n <= 1 {
            return 1
        }
        return n * compute(n - 1)
    }

    on run() {
        let r = compute(20)
        if r == 2432902008176640000 { print("OK fact(20) = {r}") } else { print("FAIL: {r}") }
    }
}
