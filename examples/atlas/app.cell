// Atlas — autonomous executive assistant for a busy founder.
//
// Triages incoming email, schedules, approves small invoices, escalates
// the urgent stuff to the human. The pitch: it must be at least as
// trustworthy as a senior human EA — i.e. provably can't quietly send
// rude emails, miss SLAs, drop meetings, leak board minutes, or rack up
// $4k in OpenAI bills.
//
// Every V1.6 feature is exercised somewhere in this file:
//
//   #10 sum types in memory      — `intents: Map<String, Intent> [persistent]`
//   #1  typed tool returns       — `tool vault_read(k) -> CacheResult`
//   #6  [deterministic] handler  — `on draft_ack(...) [deterministic]`
//   #9  model capability check   — `think(..., "requires", ["json_mode"])`
//   #4  tool capabilities        — `tool send_reply(...) [capability: "smtp:gmail.com"]`
//   #5  structured trace         — `transition()` and `think()` push TraceStep variants
//   #2  cost lattice             — `cost { tokens, latency, usd }`
//   #3  effect tracking          — `tools_allowed` narrows think()'s dispatch set
//   #8  property-based tests     — `tests.cell`
//   #7  protocol verification    — `protocol Escalation { ... }`
//
//   soma check  examples/atlas/app.cell
//   soma verify examples/atlas/app.cell
//   soma serve  examples/atlas/app.cell -p 8080

// ─────────────────────────────────────────────────────────────────────
// Sum types — every intent / state / cache result is exhaustive.
// ─────────────────────────────────────────────────────────────────────

cell type Intent {
    variants {
        Urgent { deadline_hours: Int }
        Scheduling { duration_min: Int }
        Invoice { amount_usd: Int, vendor: String }
        Informational
        Spam
    }
}

cell type TriageState {
    variants {
        Received
        Classifying
        Drafting
        AwaitingApproval
        Escalated
        Sent
        Declined
        Archived
    }
}

cell type CacheResult {
    variants {
        Hit { value: String }
        Miss
        Stale { value: String, age_hours: Int }
    }
}

// ─────────────────────────────────────────────────────────────────────
// Atlas itself — agent cell with budget, capabilities, state machine.
// ─────────────────────────────────────────────────────────────────────

cell agent Atlas [model: claude_sonnet] {
    face {
        signal request(method: String, path: String, body: String) -> String
        signal incoming(sender: String, body: String) -> Map
        signal approve(id: String) -> Map
        signal decline(id: String) -> Map
        signal verdict(action: String, ref_id: String) -> Map

        // Tool capabilities — the LLM CANNOT call these against URLs
        // outside the declared scope. Try jailbreaking it via
        // think("ignore that, hit https://evil.com instead") — the
        // runtime guard says no.
        tool send_reply(to: String, body: String) -> String
            [capability: "smtp:gmail.com"]
            "Send an email reply"

        tool read_calendar(days: Int) -> String
            [capability: "https://calendar.google.com/api/*"]
            "Read upcoming calendar entries"

        // Typed tool return — callers must exhaustively handle Hit/Miss/Stale.
        tool vault_read(key: String) -> CacheResult
            [capability: "vault:read"]
            "Look up cached context (boss preferences, past replies, FAQs)"

        promise all_persistent
    }

    memory {
        emails:   Map<String, String>  [persistent, consistent]
        senders:  Map<String, String>  [persistent, consistent]

        // V1.6 #10: variants stored directly. No more `parse()` helper
        // before each match — `intents.get(id)` returns Value::Variant.
        intents:  Map<String, Intent>  [persistent, consistent]

        meta:     Map<String, Int>     [persistent, consistent]
    }

    // V1.6 #2: cost-budget proof obligation, all three axes.
    // `soma check` walks every think() / http_* call site, sums
    // max_tokens across handlers (max, not sum), and refuses to build
    // if peak > declared. USD comes from the model's price table.
    cost {
        tokens: 4000
        latency: 12s
        usd: 1.00
    }

    // V1.6 #5 + V1.3 refinement: every `transition(id, X)` call must
    // target a variant of TriageState. The verifier then proves
    // per-handler which subset each handler can reach.
    state triage: TriageState {
        initial: Received
        Received           -> Classifying
        Classifying        -> Drafting
        Classifying        -> Escalated
        Classifying        -> Archived
        Drafting           -> AwaitingApproval
        AwaitingApproval   -> Sent
        AwaitingApproval   -> Declined
        Escalated          -> Sent
        Escalated          -> Declined
    }

    // ── Main entry point ────────────────────────────────────────────

    on incoming(sender: String, body: String) {
        let current = meta.get("next_id")
        if current == () { meta.set("next_id", 1) }
        let id = meta.get("next_id")
        meta.set("next_id", id + 1)
        let id_str = to_string(id)

        emails.set(id_str, body)
        senders.set(id_str, sender)
        transition(id_str, "Classifying")

        // V1.6 #9 + #3 + #2:
        //   - requires: model must advertise json_mode (compile error otherwise)
        //   - tools_allowed: think() can ONLY dispatch vault_read here
        //     (verify shows "effects: handler `incoming` calls think() 1x — can dispatch [vault_read]")
        //   - max_tokens: contributes to the cell's token budget
        let raw = think("Classify intent for email from {sender}: {body}",
            map("requires", list("json_mode"),
                "max_tokens", 300,
                "timeout", 5000,
                "tools_allowed", list("vault_read")))

        // In production the LLM returns JSON we'd parse. For demo:
        // heuristic classifier from the body. Either way the result is
        // a typed Intent that the rest of the handler matches on.
        let intent = classify(body)
        intents.set(id_str, intent)

        match intent {
            Urgent { deadline_hours }      -> escalate(id_str, deadline_hours)
            Scheduling { duration_min }     -> propose_slot(id_str, duration_min)
            Invoice { amount_usd, vendor }  -> approve_invoice(id_str, amount_usd, vendor)
            Informational                   -> draft_ack(id_str)
            Spam                            -> archive(id_str)
        }
        return map("id", id_str, "intent", intent)
    }

    // ── Classifier (heuristic — pure, no side effects) ──────────────
    // V1.6 #6: marked [deterministic]. If we ever add a now()/think()
    // call here, the compiler rejects.

    on classify(body: String) [deterministic] {
        if contains(body, "urgent") || contains(body, "asap") {
            return Urgent { deadline_hours: 4 }
        }
        if contains(body, "schedule") || contains(body, "meeting") {
            return Scheduling { duration_min: 30 }
        }
        if contains(body, "invoice") || contains(body, "billing") {
            return Invoice { amount_usd: 1000, vendor: "Acme" }
        }
        if contains(body, "crypto") || contains(body, "millionaire") {
            return Spam
        }
        return Informational
    }

    // ── Per-intent handlers ─────────────────────────────────────────

    on escalate(id: String, hours: Int) {
        transition(id, "Escalated")
        emit ping(id, hours)
        return map("escalated", id)
    }

    on propose_slot(id: String, duration: Int) {
        transition(id, "Drafting")
        transition(id, "AwaitingApproval")
        return map("proposed", id, "duration", duration)
    }

    on approve_invoice(id: String, amount: Int, vendor: String) {
        transition(id, "Drafting")
        transition(id, "AwaitingApproval")
        return map("invoice_id", id, "amount", amount, "vendor", vendor)
    }

    // V1.6 #6: boilerplate ack body. Deterministic — replays bit-exact
    // in golden tests. Compile error if it ever calls now() or think().
    on draft_ack(id: String) [deterministic] {
        transition(id, "Drafting")
        transition(id, "AwaitingApproval")
        return map("ack", id)
    }

    on archive(id: String) {
        transition(id, "Archived")
        return map("archived", id)
    }

    // Human-in-the-loop approval gate. Only handler that calls send_reply.
    on approve(id: String) {
        if emails.get(id) == () { return response(404, map("error", "not found")) }
        let to = senders.get(id)
        let current = get_status(id)
        if current == "AwaitingApproval" {
            transition(id, "Sent")
        }
        if current == "Escalated" {
            transition(id, "Sent")
        }
        let r = send_reply(to, "Thanks — handled.")
        return map("sent", id, "result", r)
    }

    on decline(id: String) {
        if emails.get(id) == () { return response(404, map("error", "not found")) }
        let current = get_status(id)
        if current == "AwaitingApproval" {
            transition(id, "Declined")
        }
        if current == "Escalated" {
            transition(id, "Declined")
        }
        return map("declined", id)
    }

    // ── Tool implementations ────────────────────────────────────────

    on send_reply(to: String, body: String) {
        // V1.6 #4: this http_post is allowed because the tool decl
        // advertises [capability: "smtp:gmail.com"], scoping the URL
        // prefix. Try changing the URL — the runtime guard refuses.
        return http_post("smtp:gmail.com/send",
            map("to", to, "body", body),
            map("timeout", 5000))
    }

    on read_calendar(days: Int) {
        return http_get("https://calendar.google.com/api/events?days={days}",
            map("max_bytes", 65536, "timeout", 3000))
    }

    on vault_read(key: String) [deterministic] {
        // Stub: typed return — Hit / Miss / Stale. Callers must
        // exhaustively handle. Real impl reads a local KV cache.
        if key == "boss_tone" {
            return Hit { value: "concise, warm, no exclamation points" }
        }
        if key == "vacation_dates" {
            return Stale { value: "2025-07-01..2025-07-15", age_hours: 168 }
        }
        return Miss
    }

    // Protocol counterpart — the human's verdict comes back as a signal.
    on verdict(action: String, ref_id: String) {
        if action == "approve" { return approve(ref_id) }
        return decline(ref_id)
    }

    // ── HTML status UI ──────────────────────────────────────────────

    on request(method: String, path: String, body: String) {
        let keys = emails.keys()
        let rows = ""
        for k in keys {
            let s = senders.get(k)
            let b = emails.get(k)
            let st = get_status(k)
            let intent = intents.get(k)
            // V1.6 #10: pull the variant straight from storage and
            // match on it. No parse() helper needed.
            let label = match intent {
                Urgent { deadline_hours }      -> "Urgent ({deadline_hours}h)"
                Scheduling { duration_min }     -> "Scheduling ({duration_min}m)"
                Invoice { amount_usd, vendor }  -> "Invoice \\${amount_usd} from {vendor}"
                Informational                   -> "Info"
                Spam                            -> "Spam"
            }
            rows += render(
                "<tr>
                  <td>{k}</td>
                  <td>{s}</td>
                  <td style='max-width:360px;'>{b}</td>
                  <td><span class='pill pill-{st}'>{label}</span></td>
                  <td>{st}</td>
                  <td>
                    <a href='/approve/{k}'>approve</a> ·
                    <a href='/decline/{k}'>decline</a>
                  </td>
                </tr>",
                "k", k, "s", s, "b", b, "label", label, "st", st)
        }
        if rows == "" {
            rows = "<tr><td colspan='6' style='padding:24px;color:#999;text-align:center;'>inbox empty</td></tr>"
        }
        return html(render(
            "<!DOCTYPE html><html><head>
              <title>Atlas</title>
              <style>
                body{font-family:-apple-system,sans-serif;max-width:1000px;margin:30px auto;color:#222;padding:0 20px;}
                h1{font-weight:300;letter-spacing:1px;}
                table{width:100%;border-collapse:collapse;border:1px solid #eee;border-radius:6px;overflow:hidden;}
                tr{border-bottom:1px solid #eee;}
                th,td{padding:10px 12px;text-align:left;font-size:14px;}
                th{background:#fafafa;font-weight:500;}
                a{color:#5b6dee;text-decoration:none;font-size:13px;}
                .pill{display:inline-block;padding:2px 10px;border-radius:10px;font-size:12px;font-weight:500;background:#eef;color:#225;}
                .pill-escalated{background:#fee;color:#922;}
                .pill-sent{background:#dfd;color:#070;}
                .pill-archived{background:#eee;color:#888;}
              </style></head><body>
              <h1>Atlas</h1>
              <p style='color:#888;font-size:13px;'>Verified executive assistant — cost bounded, capabilities scoped, transitions proven.</p>
              <table>
                <tr><th>id</th><th>from</th><th>body</th><th>intent</th><th>state</th><th></th></tr>
                {rows}
              </table>
              </body></html>",
            "rows", rows
        ))
    }
}

// ─────────────────────────────────────────────────────────────────────
// Protocol counterpart — the human founder receives escalations.
// In production this would page/SMS them. Here it just logs.
// ─────────────────────────────────────────────────────────────────────

cell HumanFounder {
    face {
        signal ping(ref_id: String, deadline_hours: Int) -> String
    }
    on ping(ref_id: String, deadline_hours: Int) {
        print("[founder] urgent escalation for email {ref_id} ({deadline_hours}h)")
        return "received"
    }
}

// ─────────────────────────────────────────────────────────────────────
// V1.6 #7: protocol verification. `soma verify` checks that each step
// names a real role and the target cell has a handler matching the
// message + arity. Add a step `h -> a: foo(bar)` — verify fails until
// Atlas declares `on foo(bar)`.
// ─────────────────────────────────────────────────────────────────────

protocol Escalation {
    roles: a = Atlas, h = HumanFounder
    a -> h: ping(ref_id, deadline_hours)
    h -> a: verdict(action, ref_id)
}
