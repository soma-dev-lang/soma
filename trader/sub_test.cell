use lib::connection

cell SubTest {
    memory {
        fills: Map<String, String> [ephemeral, local]
    }

    on init() {
        subscribe("ws://localhost:8081")
        print("subscribed")
    }

    on trade(data: Map) {
        print("GOT TRADE: {data}")
        fills.set(to_string(now()), to_json(data))
    }

    on ws(message: String) {
        print("GOT WS RAW: {message}")
    }

    on request(method: String, path: String, body: String) {
        return map("fills", len(fills.keys()))
    }
}
