cell Test {
    on run() {
        let items = list(
            map("name", "Alice", "score", 70),
            map("name", "Bob", "score", 85),
            map("name", "Charlie", "score", 90)
        )
        let sorted = sort_by(items, "score", "desc")
        for item in sorted { print(item.name) }
        return "done"
    }
}
