// T35: JIT - Nested function calls
cell T35 {
    on add(a: Int, b: Int) {
        return a + b
    }
    on mul(a: Int, b: Int) {
        return a * b
    }
    on run() {
        let result = add(mul(2, 3), mul(4, 5))
        print("add(mul(2,3), mul(4,5)): {result}")
        return "done"
    }
}
