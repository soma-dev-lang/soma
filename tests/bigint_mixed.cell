cell BigIntHelper {
    on big_square() {
        let big = 1000000000000000000
        return big * big
    }

    on bigint_plus_float() {
        let big = 1000000000000000000
        let sq = big * big
        return sq + 0.5
    }

    on float_plus_bigint() {
        let big = 1000000000000000000
        let sq = big * big
        return 3.14 + sq
    }

    on bigint_plus_int() {
        let big = 1000000000000000000
        let sq = big * big
        return sq + 42
    }

    on bigint_gt_float() {
        let big = 1000000000000000000
        let sq = big * big
        if sq > 1.0 { return 1 }
        return 0
    }

    on float_lt_bigint() {
        let big = 1000000000000000000
        let sq = big * big
        if 1.0 < sq { return 1 }
        return 0
    }
}

cell test BigIntMixedTests {
    rules {
        assert bigint_plus_float() > 0
        assert float_plus_bigint() > 0
        assert bigint_plus_int() > 0
        assert bigint_gt_float() == 1
        assert float_lt_bigint() == 1
    }
}
