// Test: valid_transitions changes after transition
cell SMValidAfter {
    memory {
        items: Map<String, String> [persistent, consistent]
    }
    state workflow {
        initial: draft
        draft -> review
        review -> published
        review -> rejected
        * -> cancelled
    }
    on test() {
        items.set("1", "doc")
        let v1 = valid_transitions("1")
        print("valid from draft: {v1}")
        transition("1", "review")
        let v2 = valid_transitions("1")
        print("valid from review: {v2}")
        return map("from_draft", v1, "from_review", v2)
    }
}
