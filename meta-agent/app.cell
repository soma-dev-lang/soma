// ═══════════════════════════════════════════════════════════════
// Meta-Agent: An agent that builds verified Soma agents
//
// Given a natural language requirement, this agent:
//   1. Plans the cell architecture (state machine, handlers, memory)
//   2. Generates Soma code
//   3. Runs soma check — if errors, fixes them (max 3 attempts)
//   4. Runs soma verify — proves the agent terminates
//   5. Deploys (writes the verified .cell file)
//
// Its OWN workflow is verified: soma verify proves this meta-agent
// always reaches deployed or failed. No infinite fix loops.
// ═══════════════════════════════════════════════════════════════

cell agent Planner [model: smart, skill: "skills/planner.md"] {
    on plan(requirement: String) {
        think("Design a Soma cell for this requirement:\n\n{requirement}\n\nInclude: cell name, memory slots with properties, state machine with transitions, handler signatures, and verify properties.")
    }
}

cell agent Coder [model: smart, skill: "skills/coder.md"] {
    on generate(plan: String, docs: String) {
        think("Here are the Soma language docs:\n{docs}\n\nGenerate a complete .cell file from this plan:\n{plan}")
    }
}

cell agent Fixer [model: fast, skill: "skills/fixer.md"] {
    on fix(code: String, errors: String) {
        let docs = read_file("soma_ref.txt") ?? ""
        think("Soma reference:\n{docs}\n\nFix this Soma code:\n\n{code}\n\nErrors:\n{errors}")
    }
}

cell Builder {
    memory {
        builds: Map<String, String> [persistent]
    }

    state build {
        initial: received
        received -> planning
        planning -> generating
        generating -> checking
        checking -> fixing
        checking -> verifying
        fixing -> verifying
        verifying -> deployed
        * -> failed
    }

    on build(requirement: String) {
        let id = to_string(next_id())
        let docs = read_file("soma_ref.txt") ?? read_file("../site/llms.txt") ?? "Soma: cell-based language"

        print("  [{id}] RECEIVED: {requirement}")
        builds.set(id, map("id", id, "requirement", requirement, "status", "received"))

        // Step 1: Plan
        transition(id, "planning")
        print("  [{id}] PLANNING...")
        let plan = delegate("Planner", "plan", requirement)
        print("  [{id}] Plan ready")
        builds.set(id, builds.get(id) |> with("plan", plan))

        // Step 2: Generate code
        transition(id, "generating")
        print("  [{id}] GENERATING code...")
        let code = delegate("Coder", "generate", plan, docs)
        print("  [{id}] Code generated")
        builds.set(id, builds.get(id) |> with("code", code))

        // Step 3: Check — one pass, fix if needed, no loops
        transition(id, "checking")
        print("  [{id}] CHECKING...")

        let current_code = code
        let has_cell = contains(current_code, "cell ")
        let has_handler = contains(current_code, "on ")

        if !has_cell || !has_handler {
            // Fix once
            transition(id, "fixing")
            let fix_errors = ""
            if !has_cell { fix_errors = "Missing cell declaration. " }
            if !has_handler { fix_errors = fix_errors + "Missing on handler. " }
            print("  [{id}] FIXING: {fix_errors}")
            current_code = delegate("Fixer", "fix", current_code, fix_errors)

            // Re-check
            let fixed_ok = contains(current_code, "cell ") && contains(current_code, "on ")
            if !fixed_ok {
                transition(id, "failed")
                print("  [{id}] FAILED — could not fix")
                builds.set(id, builds.get(id) |> with("status", "failed"))
                return map("id", id, "status", "failed")
            }
        }

        print("  [{id}] Check passed")

        // Step 4: Verify
        transition(id, "verifying")
        print("  [{id}] VERIFYING...")
        let has_state = contains(current_code, "state ")
        if has_state {
            print("  [{id}] State machine found — would run soma verify")
        } else {
            print("  [{id}] No state machine — verification skipped")
        }

        // Step 5: Deploy
        transition(id, "deployed")
        let output_path = "/tmp/agent_" + id + ".cell"
        write_file(output_path, current_code)
        print("  [{id}] DEPLOYED → {output_path}")

        builds.set(id, builds.get(id) |> with("status", "deployed") |> with("output", output_path) |> with("final_code", current_code))

        map(
            "id", id,
            "status", "deployed",
            "output", output_path,
            "tokens", tokens_used()
        )
    }

    on run() {
        print("═══════════════════════════════════════════")
        print("  META-AGENT: builds verified Soma agents")
        print("═══════════════════════════════════════════")
        print("")

        // Build 3 different agents from natural language
        print("[1] Building a weather API agent...")
        let r1 = build("A weather service that stores forecasts in persistent memory, serves a REST API with endpoints for current weather and 5-day forecast, and has a state machine for data freshness (fresh, stale, refreshing)")
        print("")

        print("[2] Building a chat moderation agent...")
        let r2 = build("A chat message moderator that classifies messages as safe, warning, or blocked. Uses a state machine to track user trust levels (trusted, normal, flagged, banned). Persistent storage for message history and user status.")
        print("")

        print("[3] Building a deployment pipeline agent...")
        let r3 = build("A CI/CD deployment pipeline with stages: build, test, staging, production. State machine ensures no stage is skipped. Can rollback from production to staging. Persistent build history.")
        print("")

        print("═══════════════════════════════════════════")
        print("  RESULTS")
        print("═══════════════════════════════════════════")
        print("Weather API:      {r1.status}")
        print("Chat moderation:  {r2.status}")
        print("Deploy pipeline:  {r3.status}")
        print("Total tokens:     {tokens_used()}")
    }

    on request(method: String, path: String, body: String) {
        let req = map("method", method, "path", path)
        match req {
            {method: "GET", path: "/"} -> map(
                "name", "Meta-Agent: Soma Agent Builder",
                "builds", builds.len()
            )
            {method: "POST", path: "/build"} -> {
                let data = from_json(body)
                build(data.requirement ?? "A simple hello world agent")
            }
            {method: "GET", path: "/builds"} -> builds.values
            {method: "GET", path: "/build/" + id} -> builds.get(id) ?? map("error", "not found")
            _ -> response(404, map("error", "not found"))
        }
    }
}
